{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tether.dev/schemas/provider-adapter.schema.json",
  "title": "TETHER provider adapter",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "origin",
    "adapterVersion",
    "engineVersion",
    "composer",
    "send",
    "response",
    "completion"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "origin": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://[^/?#]+$",
      "maxLength": 255
    },
    "adapterVersion": {
      "type": "integer",
      "minimum": 1
    },
    "engineVersion": {
      "const": 1
    },
    "composer": {
      "$ref": "#/$defs/requiredSelectorGroup"
    },
    "send": {
      "$ref": "#/$defs/requiredSelectorGroup"
    },
    "response": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "turnSelectors",
        "contentSelectors",
        "excludeSelectors"
      ],
      "properties": {
        "turnSelectors": {
          "$ref": "#/$defs/requiredSelectors"
        },
        "contentSelectors": {
          "$ref": "#/$defs/optionalSelectors"
        },
        "excludeSelectors": {
          "$ref": "#/$defs/optionalSelectors"
        }
      }
    },
    "completion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stopSelectors",
        "progressSelectors"
      ],
      "properties": {
        "stopSelectors": {
          "$ref": "#/$defs/optionalSelectors"
        },
        "progressSelectors": {
          "$ref": "#/$defs/optionalSelectors"
        }
      }
    }
  },
  "$defs": {
    "selector": {
      "type": "string",
      "minLength": 1,
      "maxLength": 300,
      "pattern": "^[^\\u0000-\\u001f\\u007f{}@]+$"
    },
    "requiredSelectors": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/selector"
      }
    },
    "optionalSelectors": {
      "type": "array",
      "maxItems": 16,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/selector"
      }
    },
    "requiredSelectorGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selectors"
      ],
      "properties": {
        "selectors": {
          "$ref": "#/$defs/requiredSelectors"
        }
      }
    }
  }
}
