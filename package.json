{
  "name": "@raphaelblaster/tether-cli",
  "version": "0.1.0",
  "private": true,
  "description": "TETHER Codex CLI with an embedded browser adapter",
  "type": "module",
  "bin": {
    "tether": "bin/tether.js",
    "tether-codex": "bin/tether.js"
  },
  "files": [
    "adapter/src",
    "bin",
    "docs/assets",
    "extension/dist",
    "lib",
    "README.md"
  ],
  "scripts": {
    "test": "node --test test/*.test.js && npm --prefix adapter test && npm run registry:test",
    "pack:check": "npm pack --dry-run",
    "extension:build": "npm --prefix extension run build",
    "registry:build": "node provider-adapters/scripts/build-index.mjs",
    "registry:test": "npm --prefix registry-server test"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@openai/codex": "0.143.0"
  },
  "devDependencies": {
    "playwright-core": "^1.61.1",
    "puppeteer-core": "^25.3.0"
  }
}
